# =============================================================================
# Enterprise GuardCAP - Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env file to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# Backend Configuration
# -----------------------------------------------------------------------------
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
# Optional for full persistence. The demo pipeline can run without MongoDB.
# MongoDB Atlas connection string
# Format: mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority
# MONGODB_URI=your-mongodb-connection-string-here
DATABASE_NAME=maskit

# -----------------------------------------------------------------------------
# Security & Authentication
# -----------------------------------------------------------------------------
# Generate a secure random key (minimum 32 characters)
# Example: openssl rand -hex 32
SECRET_KEY=your-secret-key-here-minimum-32-characters
DLP_SECRET_KEY=your-dlp-secret-key-minimum-32-characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ADMIN_EMAIL=admin@example.com
# Prefer ADMIN_PASSWORD_HASH for deployment. Generate it with:
# python -c "from app.auth.auth_utils import get_password_hash; print(get_password_hash('your-password'))"
ADMIN_PASSWORD_HASH=
# Local fallback only. Leave empty when ADMIN_PASSWORD_HASH is set.
ADMIN_PASSWORD=change-this-admin-password
ADMIN_NAME=MASKIT 관리자

# -----------------------------------------------------------------------------
# SMTP Configuration (Email Sending)
# -----------------------------------------------------------------------------
# SMTP is collected per user from the settings screen, not from this file.
# Keep provider examples here only as a reference for what users should enter.

# Option 1: Gmail
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USE_TLS=true
# SMTP_USE_SSL=false
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password

# Option 2: Naver
# SMTP_HOST=smtp.naver.com
# SMTP_PORT=587
# SMTP_USE_TLS=true
# SMTP_USE_SSL=false
# SMTP_USER=your-id@naver.com
# SMTP_PASSWORD=your-password

# Option 3: Mailplug
# SMTP_HOST=smtp.mailplug.co.kr
# SMTP_PORT=465
# SMTP_USE_TLS=false
# SMTP_USE_SSL=true
# SMTP_USER=your-email@example.com
# SMTP_PASSWORD=your-password-here

# -----------------------------------------------------------------------------
# Naver Cloud - CLOVA OCR (Optional)
# -----------------------------------------------------------------------------
# Get your API key from: https://www.ncloud.com/product/aiService/ocr
CLOVA_OCR_URL=your-clova-ocr-api-url
CLOVA_OCR_SECRET=your-clova-ocr-secret-key

# -----------------------------------------------------------------------------
# OpenAI API (Optional - for RAG features)
# -----------------------------------------------------------------------------
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o
OPENAI_VECTOR_STORE_ID=your-vector-store-id

# -----------------------------------------------------------------------------
# Azure OpenAI API (Optional - for live web-search based masking decisions)
# -----------------------------------------------------------------------------
# Use either AZURE_OPENAI_ENDPOINT or AZURE_OPENAI_BASE_URL.
# If Azure gives you a full URI like:
# https://yes08-mots5y11-eastus2.cognitiveservices.azure.com/openai/deployments/gpt-4.1-mini/chat/completions?api-version=2025-01-01-preview
# split it as:
# - AZURE_OPENAI_ENDPOINT: https://yes08-mots5y11-eastus2.cognitiveservices.azure.com
# - AZURE_OPENAI_BASE_URL: https://yes08-mots5y11-eastus2.cognitiveservices.azure.com/openai/v1/
# - AZURE_OPENAI_DEPLOYMENT: gpt-4.1-mini
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_ENDPOINT=https://yes08-mots5y11-eastus2.cognitiveservices.azure.com
AZURE_OPENAI_BASE_URL=https://yes08-mots5y11-eastus2.cognitiveservices.azure.com/openai/v1/
AZURE_OPENAI_DEPLOYMENT=gpt-4.1-mini
AZURE_OPENAI_MODEL=gpt-4.1-mini
AZURE_OPENAI_WEB_SEARCH_TOOL=web_search
AZURE_OPENAI_WEB_SEARCH_CONTEXT_SIZE=low

# -----------------------------------------------------------------------------
# Frontend Configuration
# -----------------------------------------------------------------------------
REACT_APP_API_URL=http://127.0.0.1:8000
VITE_API_BASE_URL=http://localhost:8000
VITE_API_URL=http://127.0.0.1:8000

# -----------------------------------------------------------------------------
# Email Receiving Server (Optional)
# -----------------------------------------------------------------------------
# RECEIVE_SERVER_HOST=your-smtp-server-host
# RECEIVE_SERVER_PORT=993
# RECEIVE_SERVER_EMAIL=your-email@example.com
# RECEIVE_SERVER_PASSWORD=your-password
# RECEIVE_SERVER_USE_SSL=true

# -----------------------------------------------------------------------------
# Additional Configuration
# -----------------------------------------------------------------------------
# Add any additional environment variables your application needs below
